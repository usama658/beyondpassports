# UKVisaCo — production .env template. Copy to .env on the server, fill real values,
# then `php artisan key:generate`. NEVER commit the real .env.

APP_NAME=UKVisaCo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

# Public base used in emails + canonicals + sitemap host
UKV_BASE_URL=https://your-domain.example
# CORS allowlist for the apply/track/upload POST endpoints (NOT *)
UKV_FRONTEND_ORIGIN=https://your-domain.example
# Owner digest recipient
UKV_OWNER_EMAIL=owner@your-domain.example
# GDPR document retention window (days after order closure)
UKV_DOC_RETENTION_DAYS=90

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ukv
DB_USERNAME=
DB_PASSWORD=

# Queue + cache + session (use a worker for database/redis; sync = inline, low volume only)
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# Mail — real transport (local was 'log')
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@your-domain.example
MAIL_FROM_NAME="${APP_NAME}"

# Stripe (test keys first, then live)
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Integrations (ROTATE the old HubSpot token before use)
HUBSPOT_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
