# Beyond Passports — production .env template. Copy to .env on the server, fill real values,
# then `php artisan key:generate`. NEVER commit the real .env.

APP_NAME="Beyond Passports"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://beyondpassports.co.uk

# Public base used in emails + canonicals + sitemap host
UKV_BASE_URL=https://beyondpassports.co.uk
# CORS allowlist for the apply/track/upload POST endpoints (NOT *)
UKV_FRONTEND_ORIGIN=https://beyondpassports.co.uk
# Owner digest recipient
UKV_OWNER_EMAIL=hello@beyondpassports.co.uk
# GDPR document retention window (days after order closure)
UKV_DOC_RETENTION_DAYS=90

# Public contact details (shown site-wide). Leave blank to fall back to placeholders.
UKV_PHONE="+44 20 1234 5678"      # human-readable display number
UKV_PHONE_E164=+442012345678       # tel: link format (leading +, digits only)
UKV_WHATSAPP=442012345678          # wa.me number (country code + digits, no + or spaces)
UKV_EMAIL=hello@beyondpassports.co.uk

# Trustpilot (third-party reviews). Widget stays hidden until the Business Unit ID is set.
# From Trustpilot Business > Integrations > TrustBox: copy the data-businessunit-id and template-id.
UKV_TRUSTPILOT_BUSINESS_UNIT_ID=6a399ad3747eb53086311900   # Beyond Passports business unit
UKV_TRUSTPILOT_TEMPLATE_ID=5419b6ffb0d04a076446a9af   # your chosen TrustBox template
UKV_TRUSTPILOT_DOMAIN=beyondpassports.co.uk           # your verified review domain
UKV_TRUSTPILOT_PROFILE_URL=          # public review-collection link (optional)
UKV_TRUSTPILOT_INVITE_BCC=beyondpassports.co.uk+bfd39d893d@invite.trustpilot.com  # Automatic Feedback BCC alias (post-delivery review invites)

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ukv
DB_USERNAME=
DB_PASSWORD=

# Queue + cache + session (use a worker for database/redis; sync = inline, low volume only)
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# Mail — real transport (local was 'log')
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@beyondpassports.co.uk
MAIL_FROM_NAME="${APP_NAME}"

# Stripe (test keys first, then live)
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Integrations (ROTATE the old HubSpot token before use)
HUBSPOT_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# WhatsApp Business (Cloud API). Blank = no-op (no customer WhatsApp pings).
# Out-of-24h-window lifecycle sends REQUIRE a Meta-approved message template.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE=order_status_update

# Travel-insurance INTRODUCER (FCA-safe signpost only; Beyond Passports takes no charge).
# Blank = neutral "ask our team" note, no outbound link.
UKV_INSURANCE_PARTNER=
UKV_INSURANCE_URL=
